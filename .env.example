# LLM
LLM_API_KEY=your-openai-compatible-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INCOMING=incoming-emails
KAFKA_CONSUMER_GROUP=email-processing-group

# MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/support_agent?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root
MYSQL_HOST_PORT=3307

# IMAP Listener (email-listener-service)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# SMTP Sender (email-processing-service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Frontend
ALLOWED_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8081
